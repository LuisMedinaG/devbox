ssh_key_names = ["mac-pub-id_ed"]   # must already exist; see `hcloud ssh-key list`

# Hetzner: prefer `export HCLOUD_TOKEN=...` over the line below to keep the
# token off disk. Uncomment only if you really want it in tfvars.
# hcloud_token = "paste-your-hetzner-api-token-here"

# Tailscale OAuth client — create at https://login.tailscale.com/admin/settings/oauth
# Required scopes: auth_keys (write), devices (read + delete)
tailscale_oauth_client_id     = "k012345CNTRL"
tailscale_oauth_client_secret = "tskey-client-xxxxxxxxxxxx"
tailscale_tailnet             = "example.com"   # shown in the admin console

# Optional overrides — defaults match the CLI workflow in README.md
# server_name = "devbox"
# server_type = "cx23"        # EU-only on some accounts; try cpx21 in ash/hil
# location    = "nbg1"        # ash = closest US region to LATAM
# image       = "ubuntu-24.04"
